{
  "name": "azjester-work-static-checks",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "test:browser": "playwright test --grep-invert @production",
    "test:browser:production": "playwright test tests/browser/production-smoke.spec.mjs",
    "test:roadmap": "node --test tests/roadmap-hardening.test.mjs",
    "build:vendor": "node scripts/build-vendor.mjs"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@supabase/supabase-js": "2.110.2"
  },
  "engines": {
    "node": ">=20"
  }
}
